# Environment Configuration
# Backend Server Settings

# Database Configuration
# Format: mysql+pymysql://username:password@host:port/database
# Default: MySQL with root user (no password)
# After setting up MySQL, update with your credentials
DATABASE_URL=mysql+pymysql://root:%40haideptrai123@localhost:3306/secure_chat
# JWT Secret Key (IMPORTANT: Change for production!)
SECRET_KEY=dev-secret-key-change-in-production-use-a-strong-random-string

# JWT Token Expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30000

AES_KEY_HEX=a1b2c3d4e5f647484a4b4c4d4e4f505152535455565758595a5b5c5d5e5f60

# SQL Logging (set to True to see SQL queries)
SQL_ECHO=False

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Notes:
# 1. After creating MySQL database and user, update DATABASE_URL with your credentials
# 2. For production, use a strong SECRET_KEY
# 3. For production, make sure RELOAD=False
# 4. Add your frontend URL to CORS_ORIGINS if hosting separately
